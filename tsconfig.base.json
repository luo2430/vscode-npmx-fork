{
  "compilerOptions": {
    "composite": true,
    "lib": ["ESNext"],
    "module": "preserve",
    "resolveJsonModule": true,
    "types": ["node"],
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noEmit": true,
    "skipLibCheck": true
  }
}
