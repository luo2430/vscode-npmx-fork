{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tsbuildinfo/app",
    "paths": {
      "#state": ["./src/state.ts"],
      "#api/*": ["./src/api/*"],
      "#types/*": ["./src/types/*"],
      "#utils/*": ["./src/utils/*"],
      "#core/*": ["./src/core/*"],
      "#composables/*": ["./src/composables/*"]
    }
  },
  "include": [
    "src/**/*",
    "tests/**/*"
  ]
}
